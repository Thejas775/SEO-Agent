# ─────────────────────────────────────────────────────────────────────────────
# SEO AI Employee — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://seo_user:your_password@localhost:5432/seo_db

# ── GOOGLE SEARCH CONSOLE ─────────────────────────────────────────────────────
# Path to service account JSON file (or the JSON string itself)
GSC_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# The site URL as registered in GSC (include trailing slash for domain property)
GSC_SITE_URL=https://yoursite.com/

# ── DATAFORSEO ────────────────────────────────────────────────────────────────
DATAFORSEO_LOGIN=your_login@email.com
DATAFORSEO_PASSWORD=your_dataforseo_password

# ── AHREFS (optional) ─────────────────────────────────────────────────────────
AHREFS_API_TOKEN=your_ahrefs_token

# ── CMS ───────────────────────────────────────────────────────────────────────
# Set CMS_TYPE to: wordpress | webflow | shopify
CMS_TYPE=wordpress
CMS_URL=https://yoursite.com
CMS_USERNAME=admin
CMS_PASSWORD=your_wordpress_password

# Webflow (if CMS_TYPE=webflow)
WEBFLOW_API_TOKEN=your_webflow_api_token
WEBFLOW_SITE_ID=your_site_id

# Shopify (if CMS_TYPE=shopify)
SHOPIFY_DOMAIN=yourstore.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_...
SHOPIFY_BLOG_ID=12345678

# ── COMPETITORS ───────────────────────────────────────────────────────────────
# Comma-separated competitor domains (no https://)
COMPETITOR_1=competitor1.com
COMPETITOR_2=competitor2.com

# ── AUDIT ─────────────────────────────────────────────────────────────────────
AUDIT_TARGET_URL=https://yoursite.com

# ── REPORTING ─────────────────────────────────────────────────────────────────
REPORT_EMAIL=your@email.com
